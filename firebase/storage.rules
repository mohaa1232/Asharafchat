rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Chat media — anyone signed in can read (simplest model for a
    // ~100-user private deployment); write only your own uploads.
    match /chats/{chatId}/media/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 100 * 1024 * 1024; // 100MB cap
    }

    match /groups/{groupId}/media/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 100 * 1024 * 1024;
    }

    match /profile_photos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
